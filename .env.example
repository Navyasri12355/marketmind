HOST=0.0.0.0
PORT=8000
ENV=development


# Local free LLM provider
LLM_PROVIDER=ollama

# --- Ollama Settings ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024
LLM_TIMEOUT=60


# Default indices
DEFAULT_INDEX=NSEI
SECONDARY_INDEX=BSESN

# Fetch interval (seconds)
MARKET_REFRESH_INTERVAL=30

SSE_KEEPALIVE=15
SSE_RETRY_TIMEOUT=3000


# Thresholds for anomaly detection
VOLUME_SPIKE_THRESHOLD=2.0
PRICE_CHANGE_THRESHOLD=0.03

# Signal scoring weights
WEIGHT_VOLUME=0.3
WEIGHT_PRICE=0.3
WEIGHT_INSIDER=0.4

RSI_PERIOD=14
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9
BB_PERIOD=20
BB_STD=2

DEFAULT_CURRENCY=INR

LOG_LEVEL=INFO
ENABLE_DEBUG_LOGS=true

